{
  "name": "vp-knowledge-pi",
  "version": "0.0.0",
  "description": "Pi overlay for vp-knowledge: Basic Memory knowledge-graph skills, session hooks, and guidance injection",
  "type": "module",
  "keywords": ["pi-package", "pi-extension", "knowledge-graph", "basic-memory"],
  "author": "Pelle Wessman <pelle@kodfabrik.se> (https://kodfabrik.se/)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voxpelli/vp-claude.git",
    "directory": "pi-package"
  },
  "files": [
    "extensions/",
    "skills/",
    "agents/",
    "lib/",
    "scripts/",
    "schemas/",
    "prompts/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  },
  "pi": {
    "extensions": ["./extensions"],
    "skills": ["./skills", "../skills"],
    "prompts": ["./prompts"]
  },
  "scripts": {
    "build": "node build.mjs",
    "check": "run-s clean && run-p check:* && run-s test",
    "check:installed-check": "installed-check",
    "check:knip": "knip",
    "check:lint": "eslint extensions/ test/",
    "check:tsc": "tsc",
    "check:type-coverage": "type-coverage --detail --strict --at-least 99 --ignore-files 'test/*'",
    "clean": "rm -f *.d.ts *.d.ts.map",
    "prepublishOnly": "node build.mjs",
    "test:node": "c8 --reporter=cobertura --reporter=lcov --reporter=text node --test",
    "test": "run-s test:*"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "dependencies": {
    "@voxpelli/typed-utils": "^5.0.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@voxpelli/eslint-config": "^25.1.0",
    "@voxpelli/tsconfig": "^16.2.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "installed-check": "^10.0.1",
    "knip": "^6.14.2",
    "npm-run-all2": "^9.0.0",
    "type-coverage": "^2.29.7",
    "typescript": "~5.9.3"
  }
}
