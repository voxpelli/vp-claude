{
  "private": true,
  "type": "module",
  "scripts": {
    "check": "run-p check:*",
    "check:hooks": "node scripts/check-hooks.mjs",
    "check:contract": "node scripts/check-staleness-contract.mjs",
    "check:distance": "node scripts/check-version-distance.mjs",
    "check:fourthwall": "node scripts/check-fourthwall.mjs",
    "check:release-counts": "node scripts/check-release-counts.mjs",
    "check:mirror": "node scripts/check-mirror.mjs",
    "check:mdast": "node scripts/check-mdast.mjs",
    "check:plugin": "node validate-plugin.mjs",
    "check:md": "remark . --quiet --frail",
    "check:sh": "shellcheck hooks/*.sh scripts/*.sh && shfmt -d hooks/*.sh scripts/*.sh"
  },
  "devDependencies": {
    "js-yaml": "^4.1.0",
    "npm-run-all2": "^7.0.0",
    "remark-cli": "^12.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-preset-lint-consistent": "^6.0.0",
    "remark-preset-lint-recommended": "^7.0.0",
    "unified": "^11.0.5"
  },
  "remarkConfig": {
    "plugins": [
      "remark-frontmatter",
      "remark-preset-lint-consistent",
      "remark-preset-lint-recommended"
    ]
  }
}
